<UserControl
    x:Class="PointlessWaymarks.WpfCommon.StringMultiSelectDataEntry.StringMultiSelectDataEntryControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:stringMultiSelectDataEntry="clr-namespace:PointlessWaymarks.WpfCommon.StringMultiSelectDataEntry"
    xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
    d:DataContext="{d:DesignInstance stringMultiSelectDataEntry:StringMultiSelectDataEntryContext}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../WpfCommonResourceDictionary.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <Label
                Content="{Binding Title}"
                Style="{StaticResource DataEntryLabelStyle}"
                Target="{Binding ElementName=ValueListBox}"
                ToolTip="{Binding HelpText}" />
            <Image
                Width="{StaticResource SmallIconSize}"
                Margin="0,0,4,0"
                VerticalAlignment="Center"
                Source="{svgc:SvgImage Source=/Icons/information-outline.svg,
                                       AppName=PointlessWaymarks.WpfCommon}"
                Visibility="{Binding HasChanges, Converter={StaticResource BooleanToVisibility}}">
                <Image.ToolTip>
                    <ToolTip Content="{Binding ReferenceValues.Count, FallbackValue='0', TargetNullValue='0'}" ContentStringFormat="Originally {0} item(s) selected" />
                </Image.ToolTip>
            </Image>
            <Image
                Width="{StaticResource SmallIconSize}"
                VerticalAlignment="Center"
                Source="{svgc:SvgImage Source=/Icons/alert-octagon.svg,
                                       AppName=PointlessWaymarks.WpfCommon}"
                ToolTip="{Binding ValidationMessage}"
                Visibility="{Binding HasValidationIssues, Converter={StaticResource BooleanToVisibility}}" />
        </StackPanel>
        <ListBox
            Name="ValueListBox"
            Grid.Row="1"
            Margin="6,4,0,0"
            ItemsSource="{Binding Choices}"
            SelectionMode="Extended">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type stringMultiSelectDataEntry:MultiSelectDataChoice}">
                    <TextBlock Text="{Binding DisplayString}" />
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
