<UserControl
    x:Class="PointlessWaymarks.WpfCommon.FeatureIntersectBrowser.FeatureIntersectResultBrowserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:behaviors="clr-namespace:PointlessWaymarks.WpfCommon.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:PointlessWaymarks.WpfCommon.FeatureIntersectBrowser"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:wpf="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
    xmlns:webViewVirtualDomain="clr-namespace:PointlessWaymarks.WpfCommon.WebViewVirtualDomain"
    d:DataContext="{d:DesignInstance local:FeatureIntersectResultBrowserContext}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../WpfCommonResourceDictionary.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid>
        <TabControl>
            <TabItem Header="Results">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="360" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <ListBox
                        HorizontalContentAlignment="Stretch"
                        ItemsSource="{Binding IntersectItems}"
                        SelectedItem="{Binding SelectedIntersectItem}"
                        SelectionMode="Single">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type local:FeatureIntersectResultListItem}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition />
                                        <RowDefinition />
                                    </Grid.RowDefinitions>
                                    <TextBox
                                        HorizontalAlignment="Stretch"
                                        BorderThickness="0"
                                        IsReadOnly="True"
                                        Text="{Binding Path=Result.Source}"
                                        TextWrapping="Wrap">
                                        <b:Interaction.Behaviors>
                                            <behaviors:ReadOnlyTextBoxClickKeyboardAndDragPass />
                                        </b:Interaction.Behaviors>
                                    </TextBox>
                                    <TextBox
                                        Grid.Row="1"
                                        Margin="12,4,4,4"
                                        BorderThickness="0"
                                        IsReadOnly="True"
                                        Text="{Binding TagString}"
                                        TextWrapping="Wrap">
                                        <b:Interaction.Behaviors>
                                            <behaviors:ReadOnlyTextBoxClickKeyboardAndDragPass />
                                        </b:Interaction.Behaviors>
                                    </TextBox>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <TabControl Grid.Column="1" ItemContainerStyle="{StaticResource UnderlineOnSelectTabItemStyle}">
                        <TabItem Header="Map">
                            <wpf:WebView2CompositionControl>
                                <b:Interaction.Behaviors>
                                    <webViewVirtualDomain:WebViewGeneratedVirtualDomainBehavior WebViewMessenger="{Binding ResultMap}" />
                                </b:Interaction.Behaviors>
                            </wpf:WebView2CompositionControl>
                        </TabItem>
                        <TabItem Header="Json">
                            <Grid>
                                <TextBox
                                    BorderThickness="0"
                                    IsReadOnly="True"
                                    Text="{Binding SelectedIntersectItem.JsonString, FallbackValue='', TargetNullValue=''}"
                                    TextWrapping="Wrap"
                                    VerticalScrollBarVisibility="Visible" />
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Grid>
            </TabItem>
            <TabItem Header="Target Feature">
                <wpf:WebView2CompositionControl>
                    <b:Interaction.Behaviors>
                        <webViewVirtualDomain:WebViewGeneratedVirtualDomainBehavior WebViewMessenger="{Binding TargetMap}" />
                    </b:Interaction.Behaviors>
                </wpf:WebView2CompositionControl>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
