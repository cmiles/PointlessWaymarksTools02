<Window x:Class="PointlessWaymarks.WpfCommon.PhotoPreview.PhotoPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:PointlessWaymarks.WpfCommon.PhotoPreview"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:status="clr-namespace:PointlessWaymarks.WpfCommon.Status"
        xmlns:windowScreenShot="clr-namespace:PointlessWaymarks.WpfCommon.WindowScreenShot"
        xmlns:starRating="clr-namespace:PointlessWaymarks.WpfCommon.StarRating"
        Title="{Binding WindowTitle}"
        Width="1000"
        Height="750"
        d:DataContext="{d:DesignInstance local:PhotoPreviewWindow}"
        mc:Ignorable="d">
    <Window.InputBindings>
        <KeyBinding Key="K" Command="{Binding PreviewContext.PreviousItemMessageCommand}" />
        <KeyBinding Key="J" Command="{Binding PreviewContext.NextItemMessageCommand}" />
        <KeyBinding Key="S" Command="{Binding PreviewContext.ToggleSharpnessCommand}" />
        <KeyBinding Key="H" Command="{Binding PreviewContext.ToggleHistogramCommand}" />
        <KeyBinding Key="M" Command="{Binding PreviewContext.ToggleMetadataOverlayCommand}" />
        <KeyBinding Key="D0" Command="{Binding PreviewContext.SetRating0Command}" />
        <KeyBinding Key="D1" Command="{Binding PreviewContext.SetRating1Command}" />
        <KeyBinding Key="D2" Command="{Binding PreviewContext.SetRating2Command}" />
        <KeyBinding Key="D3" Command="{Binding PreviewContext.SetRating3Command}" />
        <KeyBinding Key="D4" Command="{Binding PreviewContext.SetRating4Command}" />
        <KeyBinding Key="D5" Command="{Binding PreviewContext.SetRating5Command}" />
        <KeyBinding Key="U" Command="{Binding PreviewContext.ToggleFilterUnratedCommand}" />
    </Window.InputBindings>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" BorderBrush="LightGray" BorderThickness="0,0,0,1" Padding="6,4">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button Padding="8,4" Margin="2" Width="100" Command="{Binding PreviewContext.PreviousItemMessageCommand}" ToolTip="Previous Item (K)">&#x25C0; Previous</Button>
                <Button Padding="8,4" Margin="2" Width="100" Command="{Binding PreviewContext.NextItemMessageCommand}" ToolTip="Next Item (J)">Next &#x25B6;</Button>
                <Rectangle Width="1" Fill="LightGray" Margin="6,2" />
                <Button Padding="8,4" Margin="2" Click="ZoomIn_OnClick" ToolTip="Zoom In">&#x1F50D;+</Button>
                <Button Padding="8,4" Margin="2" Click="ZoomOut_OnClick" ToolTip="Zoom Out">&#x1F50D;&#x2212;</Button>
                <Button Padding="8,4" Margin="2" Click="ZoomFit_OnClick" ToolTip="Fit to Window">Fit</Button>
                <Button Padding="8,4" Margin="2" Click="ZoomActual_OnClick" ToolTip="Actual Size (100%)">1:1</Button>
                <TextBlock VerticalAlignment="Center" Margin="8,0,4,0" Text="Zoom:" />
                <TextBlock VerticalAlignment="Center" Margin="0,0,12,0"
                           Text="{Binding PreviewContext.ZoomLevel, StringFormat='{}{0:P0}'}" />
                <CheckBox VerticalAlignment="Center" Margin="8,0"
                          IsChecked="{Binding PreviewContext.ShowEdgeOverlay}"
                          Content="Sharpness (S)" ToolTip="Toggle Sharpness Overlay (S)" />
                <CheckBox VerticalAlignment="Center" Margin="8,0"
                          IsChecked="{Binding PreviewContext.ShowHistogram}"
                          Content="Histogram (H)" ToolTip="Toggle Histogram (H)" />
                <CheckBox VerticalAlignment="Center" Margin="8,0"
                          IsChecked="{Binding PreviewContext.ShowMetadataOverlay}"
                          Content="Metadata (M)" ToolTip="Toggle Metadata Overlay (M)" />
                <Rectangle Width="1" Fill="LightGray" Margin="6,2" />
                <starRating:StarRatingControl Rating="{Binding PreviewContext.Rating}" VerticalAlignment="Center" Margin="8,0" ToolTip="Rating (0-5)" />
                <Rectangle Width="1" Fill="LightGray" Margin="6,2" />
                <CheckBox VerticalAlignment="Center" Margin="8,0"
                          IsChecked="{Binding PreviewContext.FilterUnratedOnly}"
                          Content="Unrated Only (U)" ToolTip="Show only unrated photos when navigating (U)" />
                <Rectangle Width="1" Fill="LightGray" Margin="6,2" />
                <Image Source="{Binding PreviewContext.HistogramImage}"
                       Stretch="None" VerticalAlignment="Center" Margin="4,0"
                       RenderOptions.BitmapScalingMode="HighQuality">
                    <Image.Style>
                        <Style TargetType="Image">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding PreviewContext.ShowHistogram}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Image.Style>
                </Image>
                <Rectangle Width="1" Fill="LightGray" Margin="6,2" />
                <Button Click="OpenFileInExplorer_OnClick"
                        VerticalAlignment="Center" Margin="4,0"
                        Padding="6,2"
                        ToolTip="Open file location in Explorer"
                        MaxWidth="400"
                        Cursor="Hand">
                    <TextBlock Text="{Binding PreviewContext.StatusMessage}"
                               TextTrimming="CharacterEllipsis" />
                </Button>
                <ProgressBar Width="80" Height="12" Margin="8,0,0,0"
                             VerticalAlignment="Center"
                             IsIndeterminate="{Binding PreviewContext.IsLoading}">
                    <ProgressBar.Style>
                        <Style TargetType="ProgressBar">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding PreviewContext.IsLoading}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ProgressBar.Style>
                </ProgressBar>
            </WrapPanel>
        </Border>

        <!-- Image Area with Zoom -->
        <ScrollViewer Grid.Row="1"
                      x:Name="ImageScrollViewer"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      Background="#1E1E1E"
                      PreviewMouseWheel="ImageScrollViewer_OnPreviewMouseWheel"
                      PreviewMouseLeftButtonDown="ImageScrollViewer_OnPreviewMouseLeftButtonDown"
                      PreviewMouseMove="ImageScrollViewer_OnPreviewMouseMove"
                      PreviewMouseLeftButtonUp="ImageScrollViewer_OnPreviewMouseLeftButtonUp">
            <Grid x:Name="ImageContainer"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center">
                <Grid.LayoutTransform>
                    <ScaleTransform
                        ScaleX="{Binding PreviewContext.ZoomLevel}"
                        ScaleY="{Binding PreviewContext.ZoomLevel}" />
                </Grid.LayoutTransform>

                <!-- Main Image -->
                <Image x:Name="MainImage"
                       Source="{Binding PreviewContext.PreviewImage}"
                       Stretch="None"
                       RenderOptions.BitmapScalingMode="HighQuality" />

                <!-- Edge Overlay (shown on top when enabled) -->
                <Image Source="{Binding PreviewContext.EdgeOverlayImage}"
                       Stretch="Fill"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       IsHitTestVisible="False">
                    <Image.Style>
                        <Style TargetType="Image">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding PreviewContext.ShowEdgeOverlay}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Image.Style>
                </Image>
            </Grid>
        </ScrollViewer>

        <!-- Metadata Overlay (upper right of image area) -->
        <Border Grid.Row="1"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="12"
                Padding="10,8"
                Background="#AA000000"
                CornerRadius="4"
                IsHitTestVisible="False">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding PreviewContext.ShowMetadataOverlay}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding PreviewContext.MetadataOverlayText}"
                       Foreground="White"
                       FontSize="12"
                       FontFamily="Segoe UI"
                       Opacity="0.9"
                       TextAlignment="Right" />
        </Border>

        <!-- Floating Previous/Next Buttons -->
        <Button Grid.Row="1"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Margin="4,0"
                Opacity="0.7"
                FontSize="20"
                Padding="6,12"
                Command="{Binding PreviewContext.PreviousItemMessageCommand}"
                ToolTip="Previous Item (K)">&#x25C0;</Button>
        <Button Grid.Row="1"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Margin="4,0"
                Opacity="0.7"
                FontSize="20"
                Padding="6,12"
                Command="{Binding PreviewContext.NextItemMessageCommand}"
                ToolTip="Next Item (J)">&#x25B6;</Button>
        <windowScreenShot:WindowScreenShotControl
            Margin="2,2,2,6"
            Grid.Row="0"
            Grid.RowSpan="2"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom" />
        <status:StatusControl
            Grid.Row="0"
            Grid.RowSpan="2"
            d:IsHidden="true"
            DataContext="{Binding StatusContext}" />
    </Grid>
</Window>
